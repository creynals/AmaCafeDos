# amaCafe backend environment

# --- Server ---
PORT=7001
FRONTEND_URL=http://localhost:8080

# --- Database ---
DATABASE_URL=postgresql://localhost/db_taza_data

# --- Crypto ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_SECRET=change-me-in-production

# --- SumUp (Card widget embebido, CLP) ---
#
# Ciclo 15 — L2 coherence completa:
# La configuración SumUp vive en la tabla `settings` y se administra desde
# la UI /admin → "Configuración".
#
# Configuración en settings (post-migraciones 002 / 004):
#   Secretos AES-256-GCM:
#     - sumup_api_key
#     - sumup_merchant_code
#   Plano:
#     - sumup_app_id           (no sensible)
#     - sumup_mode             (mock | live, caché TTL 5min)
#     - sumup_return_url_base  (URL pública, caché TTL 5min)
#
# Configurar vía UI o endpoint:
#   POST /api/admin/settings/sumup  { api_key, merchant_code, app_id, mode, return_url_base }
#
# Ciclo 26 (Option A): HMAC webhook verification removida — el webhook de
# SumUp no se firma. La seguridad se delega a getCheckout + idempotencia.
#
# Los siguientes env vars se mantienen ÚNICAMENTE como fallback de bootstrap
# (por ejemplo, primer arranque pre-migración 004). Una vez aplicada 004 y
# configurado desde la UI, estos valores quedan ignorados.
SUMUP_MODE=mock
SUMUP_RETURN_URL_BASE=http://localhost:8080
